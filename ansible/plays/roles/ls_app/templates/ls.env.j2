# ls app specific
MYSQL_HOST={{ s.db_host }}
MYSQL_DB_NAME={{ s.db_name }}
MYSQL_USER={{ s.db_user }}
MYSQL_PWD={{ s.db_password }}
{% if s.db_root_password is defined %}
MYSQL_ROOT_PASSWORD={{ s.db_root_password }}
# MySQL container initialization variables (for staging)
MYSQL_DATABASE={{ s.db_name }}
MYSQL_PASSWORD={{ s.db_password }}
{% endif %}

# Finance DB (optional)
{% if s.db_finance_name is defined %}
MYSQL_FINANCE_DB_NAME={{ s.db_finance_name }}
MYSQL_FINANCE_USER={{ s.db_finance_user }}
MYSQL_FINANCE_PWD={{ s.db_finance_password }}
MYSQL_FINANCE_HOST={{ s.db_finance_host | default('finance-db') }}
{% if s.db_finance_root_password is defined %}
MYSQL_FINANCE_ROOT_PWD={{ s.db_finance_root_password }}
{% endif %}
{% endif %}

MOODLE_URL='{{ s.moodle_url }}/offd'
MOODLE_WSTOKEN='{{ s.moodle_wstoken }}'
SECRET_KEY='{{ s.secret_key }}'
APPROVAL_ENDPOINT='{{ s.approval_endpoint }}'
APPROVAL_TOKEN='{{ s.approval_token }}'
