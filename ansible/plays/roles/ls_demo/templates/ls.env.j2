# LeagueSphere Demo Environment Variables
# Generated by Ansible

# Django
DJANGO_SETTINGS_MODULE=league_manager.settings.demo
PYTHONUNBUFFERED=1
SECRET_KEY={{ demo_config.django.secret_key }}
DEBUG={{ demo_config.django.debug | lower }}
ALLOWED_HOSTS={{ demo_config.django.allowed_hosts | join(',') }}

# Database
MYSQL_HOST={{ demo_config.mysql.host }}
MYSQL_PORT={{ demo_config.mysql.port }}
MYSQL_ROOT_PASSWORD={{ demo_config.mysql.root_password }}
MYSQL_DATABASE={{ demo_config.mysql.database }}
MYSQL_USER={{ demo_config.mysql.user }}
MYSQL_PASSWORD={{ demo_config.mysql.password }}

# Demo
DEMO_MODE={{ demo_config.demo.mode | lower }}
DEMO_RESET_HOUR={{ demo_config.demo.reset_hour }}
DEMO_RESET_MINUTE={{ demo_config.demo.reset_minute }}

# Email (disabled for demo)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
