{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-gemini-auth@latest"],
  "mcp": {
    "circleci": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@circleci/mcp-server-circleci@latest"
      ],
      "enabled": true,
      "environment": {
        "CIRCLECI_TOKEN": "${CIRCLECI_TOKEN}",
        "CIRCLECI_BASE_URL": "${CIRCLECI_BASE_URL:-https://circleci.com}"
      }
    }
  }
}
